# convierte un string en uno válido como id de python
def to_valid_identifier(s):
    # Replace non-word chars or leading digits with _
    s = re.sub(r'\W|^(?=\d)', '_', s)
    return s
# ---------------------------------------
def is_int(s):
    try:
        int(s)
        return True
    except ValueError:
        return False

def is_float(s):
    try:
        float(s)
        return True
    except ValueError:
        return False
# ---------------------------------------
# formats: (a,n,@,$)
# fieldNames: (E,V,att,p)
# valsAtribs: [a, 4, "a;1", "a=1;b=2"]
# line: línea del evento, para localizar en caso de problemas
# devolverá: {'atomics':set('a'), 'V': 4, 'att': set('a','1'), p:dict('a':1,'b':2)}
SUF_GRAPH = "_g"

def generate_event(property_ranges, formats, fieldNames, valsAtribs, line):
    # crear valores vacíos para dicts y sets
    newEventStr = {'atomics': set()}  # siempre lo vamos a crear
    for i in range(len(formats)):  # dependerán del log
        if formats[i] == '@':  # es un conjunto de strings
            newEventStr[fieldNames[i]] = set()
        elif formats[i] == '$':  # es un diccionario, k1=v1;k2=v2; ....
            # los vi se almacenarán como strings
            newEventStr[fieldNames[i]] = dict()
            newEventStr[fieldNames[i] + SUF_GRAPH] = Graph() #también como conj. de tripletas
        elif formats[i] == 'a':  # irán a 'atomics'
            pass
        else:
            newEventStr[fieldNames[i]] = None

    # introducir los valores de los atributos en la estructura
    for i in range(len(formats)):
        if formats[i] == 'a':
            newEventStr['atomics'].add(valsAtribs[i])
        elif formats[i] == 'n':
            if is_int(valsAtribs[i]) or is_float(valsAtribs[i]):
                value = float(valsAtribs[i])
            else:
                print(
                    f"Valor incorrecto como número: {valsAtribs[i]}", file=sys.stderr)
                value = 0.0
            newEventStr[fieldNames[i]] = value
        elif formats[i] == 's':
            newEventStr[fieldNames[i]] = valsAtribs[i]
        elif formats[i] == '@':
            for v in valsAtribs[i].split(VALS_SEP):
                newEventStr[fieldNames[i]].add(v.strip())
        elif formats[i] == '$':
            # aplicar ontología a valores de atributos en diccionario
            for v in valsAtribs[i].split(VALS_SEP):
                # print(f"{valsAtribs[i]}")
                try: 
                    [key, value] = [s.strip() for s in v.split('=')]
                    newEventStr[fieldNames[i]][key] = cast_value(
                        property_ranges, key, value)

                    # también como tripletas
                    subject_uri = EX[str(line)]
                    key_parts = key.split(":")
                    predicate_uri = DOMAIN_ONTOLOGY[key_parts[len(key_parts)-1]]

                    newEventStr[fieldNames[i] + SUF_GRAPH].add((subject_uri, predicate_uri, Literal(value)))
                except Exception as e:
                    print(f"Error procesando valores de atributo diccionario: {e}", file=sys.stderr)
                    print(f"line {line}: {v}", file=sys.stderr)
        else:
            print("Formato de atributo incorrecto", file=sys.stderr)

    return newEventStr
