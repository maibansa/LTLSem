def save_results(logData, results, results_counts):
    with open(logData['path'] + '.res', "w") as fR:
        with open(logData['path'] + '.norm', "w") as fC:
            for id in logData['sortedIDs']:
                fR.write(f"{results[id]}\n")
                fC.write(f"{results_counts[id]}\n")

# results[id] = "id,1,0,1,...
def who(logData, results):
    return what(logData, results, '1')


def who_not(logData, results):
    return what(logData, results, '0')

def what(logData, results, val):
    listIds = ""
    for id in logData['sortedIDs']:
        res = results[id].rpartition(',')[-1]  # todo de después de última ','
        if res == val:
            listIds += id + " "
    return listIds
# ---------------------------------------
# Dada una fórmula, posiblemente con macros del tipo '?activities' y
# un diccionario del tipo {...,'?activities':('cargar','marcar','descargar'), ...}
# genera una lista de fórmulas, una por cada posible valor de '?activities'
# Si intervienen varios diccionarios, se generan fórmulas para el producto
# cartesiano de todos los diccionarios
# OjO para diccionarios grandes.
def unfoldMacros(formulaWithMacros, dictMacros):
    keysInString = [key for key in dictMacros if key in formulaWithMacros]

    if not keysInString:
        return [formulaWithMacros]  # no hay macros

    # lista de todos los valores a sustituir
    replacementLists = [dictMacros[key] for key in keysInString]

    result = []
    for combo in product(*replacementLists):
        temp = formulaWithMacros
        for key, value in zip(keysInString, combo):
            temp = temp.replace(key, value)
        result.append(temp)

    return result
